#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]:-$0}")" && pwd)"
PLUGIN_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"

# Lightweight context - just the essentials
LIGHTWEIGHT_CONTEXT="# Unravel Plugin Loaded

Unravel extracts business artifacts from code automatically.

## Available Commands

- \"Extract business rules from [files]\" - Extract conditional logic, validation, exceptions
- \"Extract process flows from [files]\" - Extract function chains, state machines, workflows
- \"Extract data specs from [files]\" - Extract schemas, ORMs, DTOs, interfaces
- \"Extract user stories from [files]\" - Extract controllers, routes, endpoints
- \"Extract security/nfrs from [files]\" - Extract middleware, auth, logging, rate limiting
- \"Extract integrations from [files]\" - Extract HTTP calls, APIs, env vars, webhooks

## When to Use

Use Unravel when analyzing codebases for:
- Business rule documentation
- Process flow mapping
- Data specification discovery
- User story generation
- Security audit
- Dependency analysis

## Architecture

**Simple path (< 10 files):** Uses unravel-extractor (single agent, extract + self-verify)

**Complex path (10+ files):** Uses unravel-orchestrator → parallel workers → unravel-merger

All outputs saved to: docs/output/
"

escape_for_json() {
    local s="$1"
    s="${s//\\/\\\\}"
    s="${s//\"/\\\"}"
    s="${s//$'\n'/\\n}"
    s="${s//$'\r'/\\r}"
    s="${s//$'\t'/\\t}"
    printf '%s' "$s"
}

context_escaped=$(escape_for_json "$LIGHTWEIGHT_CONTEXT")
session_context="<system-reminder>\n${context_escaped}\n</system-reminder>"

cat <<EOF
{
  "additional_context": "${session_context}",
  "hookSpecificOutput": {
    "hookEventName": "SessionStart",
    "additionalContext": "${session_context}"
  }
}
EOF

exit 0
