#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]:-$0}")" && pwd)"
PLUGIN_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"

# Load the full using-unravel skill at session start
FULL_SKILL_CONTEXT="# Unravel Plugin Loaded

Use the Skill tool to read: ${PLUGIN_ROOT}/skills/using-unravel/SKILL.md

This provides complete documentation on:
- Available artifact types and when to use each
- Architecture overview
- How to invoke Unravel correctly
- All agents and their responsibilities
- Output locations

**Key:** When extracting multiple artifact types, launch separate orchestrating-extraction workflows for each type. Do not combine into a single call.
"

escape_for_json() {
    local s="$1"
    s="${s//\\/\\\\}"
    s="${s//\"/\\\"}"
    s="${s//$'\n'/\\n}"
    s="${s//$'\r'/\\r}"
    s="${s//$'\t'/\\t}"
    printf '%s' "$s"
}

context_escaped=$(escape_for_json "$FULL_SKILL_CONTEXT")
session_context="<system-reminder>\n${context_escaped}\n</system-reminder>"

cat <<EOF
{
  "additional_context": "${session_context}",
  "hookSpecificOutput": {
    "hookEventName": "SessionStart",
    "additionalContext": "${session_context}"
  }
}
EOF

exit 0
